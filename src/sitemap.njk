---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://participatorymind.org/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://participatorymind.org/articles</loc>
    <changefreq>weekly</changefreq>
    <priority>0.85</priority>
  </url>
  <url>
    <loc>https://participatorymind.org/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  {% for article in collections.articles %}
  <url>
    <loc>https://participatorymind.org{{ article.url | replace(".html", "") }}</loc>
    <lastmod>{{ article.data.date | isoDate }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}
</urlset>
